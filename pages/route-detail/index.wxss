@import '../../app.wxss';

.xinjiang-detail {
  padding-bottom: 24rpx;
}

.xj-hero {
  position: relative;
  height: 560rpx;
  overflow: hidden;
  border-radius: 34rpx;
  box-shadow: 0 24rpx 54rpx rgba(31, 98, 167, 0.18);
}

.xj-hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

.xj-hero-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(6, 55, 88, 0.50)),
    linear-gradient(90deg, rgba(7, 76, 108, 0.26), rgba(255, 255, 255, 0.03));
}

.xj-hero-content {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 34rpx;
  color: #ffffff;
}

.xj-kicker {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #ffe0a0;
  background: rgba(7, 82, 117, 0.58);
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.xj-title {
  margin-top: 18rpx;
  font-size: 62rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  text-shadow: 0 6rpx 18rpx rgba(0, 50, 86, 0.30);
}

.xj-subtitle {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
}

.xj-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.xj-meta-row text {
  padding: 9rpx 14rpx;
  border-radius: 999rpx;
  color: #0f4f77;
  background: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 800;
}

.xj-overview-strip {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin: -34rpx 18rpx 20rpx;
}

.xj-overview-item {
  min-height: 116rpx;
  padding: 18rpx 10rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(20, 94, 168, 0.08);
  box-shadow: 0 14rpx 30rpx rgba(31, 98, 167, 0.10);
  text-align: center;
}

.xj-overview-num {
  display: block;
  color: #0d4f79;
  font-size: 34rpx;
  font-weight: 900;
}

.xj-overview-label {
  display: block;
  margin-top: 6rpx;
  color: #70849a;
  font-size: 21rpx;
}

.xj-card {
  margin-top: 18rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(20, 94, 168, 0.10);
  box-shadow: 0 14rpx 30rpx rgba(31, 98, 167, 0.07);
}

.xj-invite-card {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(239, 248, 251, 0.92));
}

.xj-invite-card::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -90rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(20, 94, 168, 0.10);
}

.xj-invite-main,
.xj-invite-lines,
.xj-scenic-panel,
.xj-slogan {
  position: relative;
  z-index: 2;
}

.xj-section-kicker {
  color: #d6a92a;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.xj-section-title {
  margin-top: 8rpx;
  color: #0d4f79;
  font-size: 44rpx;
  font-weight: 900;
}

.xj-quote {
  margin-top: 18rpx;
  color: #13263f;
  font-size: 30rpx;
  line-height: 1.7;
  font-weight: 700;
}

.xj-copy {
  margin-top: 16rpx;
  color: #425b76;
  font-size: 26rpx;
  line-height: 1.72;
}

.xj-scenic-panel {
  position: relative;
  height: 220rpx;
  margin-top: 24rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.xj-scenic-image {
  width: 100%;
  height: 100%;
  display: block;
}

.xj-scenic-panel::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(11, 86, 104, 0.64), rgba(11, 86, 104, 0.08));
}

.xj-scenic-caption {
  position: absolute;
  left: 24rpx;
  bottom: 20rpx;
  z-index: 2;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.xj-slogan {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(20, 94, 168, 0.12);
  color: #0d4f79;
  font-size: 34rpx;
  font-weight: 900;
  text-align: center;
  letter-spacing: 4rpx;
}

.xj-section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin: 30rpx 0 14rpx;
}

.xj-theme-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.xj-theme-card,
.xj-notice-card {
  position: relative;
  overflow: hidden;
  min-height: 190rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(20, 94, 168, 0.10);
  box-shadow: 0 12rpx 24rpx rgba(56, 96, 140, 0.05);
}

.xj-theme-card::after {
  content: '';
  position: absolute;
  right: -30rpx;
  bottom: -40rpx;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(20, 94, 168, 0.05);
}

.xj-theme-mark {
  color: #d6a92a;
  font-size: 18rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.xj-theme-title {
  position: relative;
  z-index: 2;
  margin-top: 10rpx;
  color: #0d6a61;
  font-size: 32rpx;
  font-weight: 900;
}

.xj-theme-text,
.xj-notice-text {
  position: relative;
  z-index: 2;
  margin-top: 12rpx;
  color: #70849a;
  font-size: 24rpx;
  line-height: 1.58;
}

.xj-stage-card {
  display: grid;
  grid-template-columns: 170rpx 1fr;
  gap: 18rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(20, 94, 168, 0.10);
  box-shadow: 0 14rpx 30rpx rgba(31, 98, 167, 0.07);
}

.xj-stage-side {
  min-height: 180rpx;
  padding: 18rpx 14rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(239, 248, 251, 0.96), rgba(255, 255, 255, 0.88));
}

.xj-stage-index {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #0d6a61;
  font-size: 30rpx;
  font-weight: 900;
}

.xj-stage-title {
  margin-top: 14rpx;
  color: #13263f;
  font-size: 27rpx;
  font-weight: 900;
}

.xj-stage-subtitle {
  margin-top: 8rpx;
  color: #0d6a61;
  font-size: 24rpx;
  line-height: 1.35;
}

.xj-stage-blue .xj-stage-index {
  background: #145ea8;
}

.xj-stage-blue .xj-stage-subtitle {
  color: #145ea8;
}

.xj-stage-gold .xj-stage-index {
  background: #d6a92a;
}

.xj-stage-gold .xj-stage-subtitle {
  color: #b88919;
}

.xj-stage-main {
  position: relative;
  padding-left: 6rpx;
}

.xj-stage-line {
  position: absolute;
  left: 10rpx;
  top: 12rpx;
  bottom: 58rpx;
  width: 2rpx;
  background: linear-gradient(180deg, rgba(13, 106, 97, 0.26), rgba(214, 169, 42, 0.28));
}

.xj-day-row {
  position: relative;
  padding-left: 30rpx;
  color: #425b76;
  font-size: 23rpx;
  line-height: 1.58;
}

.xj-day-row::before {
  content: '';
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #d6a92a;
  box-shadow: 0 0 0 6rpx rgba(214, 169, 42, 0.10);
}

.xj-places {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1px dashed rgba(20, 94, 168, 0.16);
  color: #90a0b2;
  font-size: 22rpx;
  line-height: 1.5;
}

.xj-notice-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.xj-notice-title {
  color: #13263f;
  font-size: 28rpx;
  font-weight: 900;
}

.xj-contact-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0d6a61, #145ea8);
  box-shadow: 0 18rpx 36rpx rgba(31, 98, 167, 0.16);
}

.xj-contact-card .primary-btn {
  flex-shrink: 0;
  color: #0d4f79;
  background: #ffffff;
}

.xj-contact-title {
  font-size: 30rpx;
  font-weight: 900;
}

.xj-contact-phone {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 25rpx;
}
