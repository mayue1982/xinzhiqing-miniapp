<view class="screen-page">
  <view class="custom-nav with-back">
    <button class="back-btn" bindtap="goBack">‹</button>
    <view class="brand-wrap">
      <view class="brand-dot">线</view>
      <view class="brand-stack">
        <text class="brand-stack-title">路线详情</text>
        <text class="brand-stack-subtitle">ROUTE DETAIL</text>
      </view>
    </view>
  </view>

  <view class="xinjiang-detail" wx:if="{{route && route.id === 'route-xj-aug'}}">
    <view class="xj-hero">
      <image class="xj-hero-image" src="{{route.image}}" mode="aspectFill" />
      <view class="xj-hero-mask"></view>
      <view class="xj-hero-content">
        <text class="xj-kicker">心爱自然 · 新疆生命之旅</text>
        <view class="xj-title">{{route.title}}</view>
        <view class="xj-subtitle">{{route.desc}}</view>
        <view class="xj-meta-row">
          <text>{{route.dateRange}}</text>
          <text>{{route.duration}}</text>
        </view>
      </view>
    </view>

    <view class="xj-overview-strip">
      <view class="xj-overview-item">
        <text class="xj-overview-num">24</text>
        <text class="xj-overview-label">天生命之旅</text>
      </view>
      <view class="xj-overview-item">
        <text class="xj-overview-num">4</text>
        <text class="xj-overview-label">阶段递进</text>
      </view>
      <view class="xj-overview-item">
        <text class="xj-overview-num">8月</text>
        <text class="xj-overview-label">即将启程</text>
      </view>
    </view>

    <view class="xj-card xj-invite-card">
      <view class="xj-invite-main">
        <view class="xj-invite-heading">
          <view class="xj-section-kicker">INVITATION</view>
          <view class="xj-section-title">邀请函</view>
        </view>
        <view class="xj-quote">{{route.longDesc}}</view>
        <view class="xj-copy">{{route.themeIntro}}</view>
      </view>
      <view class="xj-scenic-panel">
        <image class="xj-scenic-image" src="/assets/images/route-culture.jpg" mode="aspectFill"></image>
        <view class="xj-scenic-caption">山河为课堂，文明伴同行</view>
      </view>
      <view class="xj-invite-lines">
        <view wx:for="{{route.invitation}}" wx:key="*this" class="xj-copy">{{item}}</view>
      </view>
      <view class="xj-slogan">{{route.slogan}}</view>
    </view>

    <view class="xj-section-head">
      <text class="section-head-title">四大核心主题</text>
      <text class="section-head-subtitle">NATURE · CULTURE</text>
    </view>
    <view class="xj-theme-grid">
      <view wx:for="{{route.coreThemes}}" wx:key="title" class="xj-theme-card">
        <view class="xj-theme-mark">0{{index + 1}}</view>
        <view class="xj-theme-title">{{item.title}}</view>
        <view class="xj-theme-text">{{item.text}}</view>
      </view>
    </view>

    <view class="xj-journey-banner">
      <image class="xj-journey-image" src="/assets/images/xinjiang-invitation-banner.jpg" mode="aspectFill"></image>
      <view class="xj-journey-mask"></view>
      <view class="xj-journey-copy">
        <text class="xj-journey-kicker">XINJIANG FIELD JOURNEY</text>
        <view class="xj-journey-title">心向自然，行走新疆</view>
      </view>
    </view>

    <view class="xj-section-head">
      <text class="section-head-title">行程与活动流程</text>
      <text class="section-head-subtitle">2026 AUGUST</text>
    </view>
    <view wx:for="{{route.stages}}" wx:key="title" class="xj-stage-card xj-stage-{{item.color}}">
      <view class="xj-stage-side">
        <view class="xj-stage-index">{{index + 1}}</view>
        <view class="xj-stage-title">{{item.title}}</view>
        <view class="xj-stage-subtitle">{{item.subtitle}}</view>
      </view>
      <view class="xj-stage-main">
        <view class="xj-stage-line"></view>
        <view wx:for="{{item.days}}" wx:for-item="day" wx:key="*this" class="xj-day-row">{{day}}</view>
        <view class="xj-places">{{item.places}}</view>
      </view>
    </view>

    <view class="xj-section-head">
      <text class="section-head-title">出行须知</text>
      <text class="section-head-subtitle">NOTICE</text>
    </view>
    <view class="xj-notice-grid">
      <view wx:for="{{route.notices}}" wx:key="title" class="xj-notice-card">
        <view class="xj-notice-title">{{item.title}}</view>
        <view class="xj-notice-text">{{item.text}}</view>
      </view>
    </view>

    <view class="xj-contact-card">
      <view>
        <view class="xj-contact-title">报名方式</view>
        <view class="xj-contact-phone">电话：{{route.phone}}</view>
      </view>
      <button class="primary-btn" bindtap="startConsult">提交咨询</button>
    </view>
  </view>

  <block wx:elif="{{route}}">
  <view class="page-overview glass-card" wx:if="{{route}}">
    <text class="overview-kicker">Featured Journey</text>
    <view class="overview-title">{{route.title}}</view>
    <view class="overview-copy">{{route.desc}}</view>
  </view>

  <view class="hero-card" wx:if="{{route}}">
    <text class="hero-badge">Featured Route</text>
    <view class="hero-title-en">{{route.subtitle}}</view>
    <view class="hero-title-zh">{{route.title}}</view>
    <view class="hero-copy">{{route.longDesc}}</view>
  </view>

  <view class="info-grid" wx:if="{{route}}">
    <view class="info-item">
      <view class="info-label">适合人群</view>
      <view class="info-value">{{route.audience}}</view>
    </view>
    <view class="info-item">
      <view class="info-label">体验重点</view>
      <view class="info-value">{{route.highlights}}</view>
    </view>
  </view>

  <view class="note-card">
    <view class="section-head" style="margin-top:0;">
      <text class="section-head-title">路线介绍</text>
      <text class="section-head-subtitle">OVERVIEW</text>
    </view>
    <view class="card-copy">{{route.longDesc}}</view>
  </view>

  <view class="hero-actions" style="margin-top:18rpx;">
    <button class="primary-btn" bindtap="startConsult">提交咨询</button>
    <button class="outline-btn" bindtap="goHome">返回首页</button>
  </view>
  </block>
</view>
