<view class="screen-page">
  <view class="custom-nav with-back">
    <button class="back-btn" bindtap="goBack">‹</button>
    <view class="brand-wrap">
      <view class="brand-dot">咨</view>
      <view class="brand-stack">
        <text class="brand-stack-title">顾问咨询</text>
        <text class="brand-stack-subtitle">ADVISOR</text>
      </view>
    </view>
  </view>

  <view class="page-overview glass-card">
    <text class="overview-kicker">Advisor Bridge</text>
    <view class="overview-title">咨询、报名与顾问承接放在一起</view>
    <view class="overview-copy">第一阶段先用小程序客服与顾问跟进承接用户，报名和成长定制提交记录也会汇总在这里。</view>
  </view>

  <view class="advisor-card" wx:if="{{contact.advisor}}">
    <view class="advisor-row">
      <view class="advisor-avatar">{{contact.advisor.avatar}}</view>
      <view>
        <view class="card-title" style="color:#fff; margin-bottom:4rpx;">{{contact.advisor.name}}</view>
        <view class="card-copy" style="color:rgba(255,255,255,.88);">{{contact.advisor.role}}</view>
      </view>
    </view>
    <view class="metric-grid">
      <view class="metric"><text class="metric-num">客服</text><text class="metric-label">咨询入口</text></view>
      <view class="metric"><text class="metric-num">{{contact.advisor.hours}}</text><text class="metric-label">服务时段</text></view>
      <view class="metric"><text class="metric-num">24H</text><text class="metric-label">跟进</text></view>
    </view>
  </view>

  <view class="glass-card" wx:if="{{contact.advisor}}">
    <view class="section-head" style="margin-top:0;">
      <text class="section-head-title">联系顾问</text>
      <text class="section-head-subtitle">SERVICE</text>
    </view>
    <view class="contact-actions">
      <button class="primary-btn" open-type="contact">小程序客服</button>
      <button class="outline-btn" bindtap="copyWechat">复制微信</button>
      <button class="outline-btn" bindtap="copyPhone">复制电话</button>
    </view>
  </view>

  <view class="section-head">
    <text class="section-head-title">咨询记录</text>
    <text class="section-head-subtitle">RECORDS</text>
  </view>

  <view wx:if="{{consultations.length}}">
    <view wx:for="{{consultations}}" wx:key="id" class="timeline-card">
      <view class="section-head" style="margin-top:0;">
        <text class="timeline-title">{{item.title}}</text>
        <text class="status-pill">{{item.status}}</text>
      </view>
      <view class="timeline-copy">{{item.summary}}</view>
      <view class="timeline-foot">
        <text class="timeline-meta">{{item.id}}</text>
        <text class="timeline-meta">{{item.updatedAt}}</text>
      </view>
    </view>
  </view>

  <view class="empty-card" wx:else>
    <view class="empty-title">暂无咨询记录</view>
    <view class="empty-copy">当顾问开始跟进后，后续沟通会沉淀在这里。</view>
  </view>
</view>
