<view class="screen-page">
  <view class="custom-nav with-back">
    <button class="back-btn" bindtap="goBack">‹</button>
    <view class="brand-wrap">
      <view class="brand-dot">藏</view>
      <view class="brand-stack">
        <text class="brand-stack-title">我的收藏</text>
        <text class="brand-stack-subtitle">FAVORITES</text>
      </view>
    </view>
  </view>

  <view class="page-overview glass-card">
    <text class="overview-kicker">Preference Signals</text>
    <view class="overview-title">高意向路线会先沉淀在这里</view>
    <view class="overview-copy">收藏页能帮助顾问判断用户当前更偏向哪一种成长方向，这也是领导关心的转化信号之一。</view>
  </view>

  <view wx:if="{{favorites.length}}">
    <view wx:for="{{favorites}}" wx:key="id" class="glass-card" style="margin-bottom:12rpx;" data-id="{{item.routeId}}" bindtap="openRoute">
      <view class="section-head" style="margin-top:0;">
        <text class="card-title" style="margin-bottom:0;">{{item.title}}</text>
        <text class="status-pill">{{item.tag}}</text>
      </view>
      <view class="card-subtitle">{{item.subtitle}}</view>
      <view class="card-copy">{{item.desc}}</view>
    </view>
  </view>

  <view class="empty-card" wx:else>
    <view class="empty-title">还没有收藏路线</view>
    <view class="empty-copy">用户浏览路线后，后续可以把偏好路线沉淀到这里。</view>
  </view>
</view>
