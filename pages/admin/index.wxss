@import "../../app.wxss";

.admin-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.admin-password-field {
  margin-top: 12rpx;
}

.admin-request-card {
  margin-bottom: 16rpx;
}

.record-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.mini-action {
  width: 100%;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0;
  border-radius: 999rpx;
  border: 1px solid rgba(20, 94, 168, 0.18);
  background: rgba(255, 255, 255, 0.82);
  color: #1a5f9e;
  font-size: 23rpx;
  font-weight: 700;
}

.mini-action::after {
  border: 0;
}

.mini-action.primary {
  border-color: rgba(226, 170, 43, 0.34);
  background: #e6b447;
  color: #113a62;
}

.mini-action.danger {
  border-color: rgba(217, 48, 37, 0.18);
  color: #b3261e;
}
