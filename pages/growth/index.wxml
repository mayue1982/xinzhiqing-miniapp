<view class="screen-page">
  <view class="custom-nav">
    <view class="brand-wrap">
      <view class="brand-dot">定</view>
      <view class="brand-stack">
        <text class="brand-stack-title">成长定制</text>
        <text class="brand-stack-subtitle">MIND GROWTH</text>
      </view>
    </view>
  </view>

  <view class="hero-card">
    <text class="hero-badge">Personal Request</text>
    <view class="hero-title-en">Tailor Your
Growth Journey</view>
    <view class="hero-title-zh">面 向 个 人 的 成 长 申 请</view>
    <view class="hero-copy">围绕心灵培训旅游线路与主题游学，先完成需求采集，再由顾问协助匹配路线。</view>
    <view class="hero-copy-en">A guided request flow for training routes, study journeys, and tailored travel arrangements.</view>
  </view>

  <view class="chip-row">
    <view
      wx:for="{{chips}}"
      wx:key="*this"
      class="chip {{item === selectedChip ? 'chip-active' : ''}}"
      data-value="{{item}}"
      bindtap="selectChip"
    >{{item}}</view>
  </view>

  <view class="form-card glass-card">
    <view class="section-head" style="margin-top:0;">
      <text class="section-head-title">需求采集</text>
      <text class="section-head-subtitle">STEP 1</text>
    </view>
    <view class="field-row">
      <input class="field" placeholder="出发城市 / Departure" value="{{form.city}}" data-field="city" bindinput="updateField" />
      <input class="field" placeholder="目的地方向 / Destination" value="{{form.destination}}" data-field="destination" bindinput="updateField" />
    </view>
    <view class="field-row">
      <input class="field" placeholder="人数 / Group Size" value="{{form.groupSize}}" data-field="groupSize" bindinput="updateField" />
      <input class="field" placeholder="时间 / Time Window" value="{{form.timeWindow}}" data-field="timeWindow" bindinput="updateField" />
    </view>
    <view class="field-row">
      <input class="field" placeholder="预算 / Budget" value="{{form.budget}}" data-field="budget" bindinput="updateField" />
      <input class="field" placeholder="类型 / Service Type" value="{{form.serviceType}}" data-field="serviceType" bindinput="updateField" />
    </view>
    <textarea class="textarea" placeholder="简单描述你想参加的培训主题、游学目标、线路方向或特别需求。" value="{{form.note}}" data-field="note" bindinput="updateField"></textarea>
    <view class="hero-actions" style="margin-top:18rpx;">
      <button class="primary-btn" loading="{{submitting}}" bindtap="submitRequest">提交顾问</button>
      <button class="outline-btn" bindtap="saveDraft">保存</button>
    </view>
  </view>
</view>
