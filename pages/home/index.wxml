<view class="screen-page home-page">
  <view class="custom-nav">
    <view class="brand-wrap">
      <view class="brand-dot">心</view>
      <view class="brand-stack">
        <text class="brand-stack-title">心之清文旅</text>
        <text class="brand-stack-subtitle">XINZHIQING CULTURAL TOURISM</text>
      </view>
    </view>
  </view>

  <view class="visual-hero-shell">
    <swiper class="visual-swiper visual-swiper-hero" autoplay circular interval="4200" duration="600" indicator-dots indicator-color="rgba(255,255,255,.45)" indicator-active-color="#efbc52">
      <swiper-item wx:for="{{carouselItems}}" wx:key="image">
        <view class="visual-slide">
          <image class="visual-image" src="{{item.image}}" mode="aspectFill"></image>
        </view>
      </swiper-item>
    </swiper>
    <view class="visual-mask"></view>
    <view class="visual-copy">
      <text class="visual-badge">Global Mind Growth Journey</text>
      <view class="visual-title-en">Xinzhiqing
Cultural Tourism</view>
      <view class="visual-title-zh">心 之 清 文 旅 · 入 道 调 心 境</view>
      <view class="visual-desc">在星空与自然之间，回到更清楚、更纯粹的自己。</view>
    </view>
  </view>

  <view class="search-entry">
    <view class="search-symbol"></view>
    <view class="search-copy">
      <text class="search-title">您想去哪里</text>
      <text class="search-subtitle">目的地｜出行人｜时间</text>
    </view>
    <view class="search-btn">搜索</view>
  </view>

  <view class="quick-grid quick-grid-illustrated">
    <view wx:for="{{quickItems}}" wx:key="title" class="quick-card">
      <view class="quick-visual {{item.iconClass}}">
        <view class="quick-shape quick-shape-a"></view>
        <view class="quick-shape quick-shape-b"></view>
        <view class="quick-shape quick-shape-c"></view>
      </view>
      <view class="quick-label">{{item.title}}</view>
    </view>
  </view>

  <view class="featured-route" data-id="{{featuredRoute.id}}" bindtap="openRoute">
    <image class="featured-route-image" src="{{featuredRoute.image}}" mode="aspectFill"></image>
    <view class="featured-route-mask"></view>
    <view class="featured-route-content">
      <text class="featured-route-tag">{{featuredRoute.tag}}</text>
      <view class="featured-route-title">{{featuredRoute.title}}</view>
      <view class="featured-route-desc">{{featuredRoute.desc}}</view>
      <view class="featured-route-foot">
        <text>{{featuredRoute.meta}}</text>
        <text>查看详情</text>
      </view>
    </view>
  </view>

  <view class="section-head">
    <text class="section-head-title">精选路线</text>
    <text class="section-head-subtitle">FEATURED</text>
  </view>

  <view class="route-square-grid">
    <view wx:for="{{routes}}" wx:key="id" class="route-square-card" data-id="{{item.id}}" bindtap="openRoute">
      <image class="route-thumb-image" src="{{item.image}}" mode="aspectFill"></image>
      <view class="route-square-body">
        <view class="card-title">{{item.title}}</view>
        <view class="card-subtitle">{{item.subtitle}}</view>
        <view class="card-copy">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>
