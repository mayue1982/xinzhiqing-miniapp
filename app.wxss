page {
  background: linear-gradient(180deg, #fafcff 0%, #f1f6fb 100%);
  color: #13263f;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

view,
text,
button,
navigator,
input,
textarea {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.screen-page {
  min-height: 100vh;
  padding: 62rpx 24rpx 140rpx;
  background:
    radial-gradient(circle at 20% 0%, rgba(217, 235, 255, 0.9), transparent 32%),
    linear-gradient(180deg, #fafcff 0%, #f1f6fb 100%);
}

.custom-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 132rpx;
  padding: 58rpx 8rpx 12rpx;
}

.custom-nav.with-back {
  position: relative;
  justify-content: flex-start;
  align-items: center;
  padding-left: 44rpx;
  padding-right: 8rpx;
}

.back-btn {
  position: absolute;
  left: 0;
  top: 60rpx;
  width: 36rpx;
  height: 36rpx;
  min-width: 36rpx;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: rgba(20, 94, 168, 0.78);
  font-size: 32rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  box-shadow: none;
}

.with-back .brand-wrap {
  margin: 0;
  max-width: 420rpx;
}

.brand-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-dot {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #145ea8, #4ea4f5);
}

.brand-stack {
  display: flex;
  flex-direction: column;
  line-height: 1.04;
}

.brand-stack-title {
  color: #13263f;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.brand-stack-subtitle {
  color: #70849a;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-card {
  position: relative;
  overflow: hidden;
  margin: 18rpx 0 24rpx;
  padding: 36rpx;
  border-radius: 28rpx;
  color: #ffffff;
  background:
    linear-gradient(135deg, rgba(15, 95, 180, 0.96), rgba(78, 164, 245, 0.78)),
    url('https://images.unsplash.com/photo-1462331940025-496dfbfc7564?auto=format&fit=crop&w=1200&q=80') center/cover;
  box-shadow: 0 18rpx 36rpx rgba(31, 98, 167, 0.14);
}

.hero-card::after {
  content: '';
  position: absolute;
  right: -60rpx;
  bottom: -50rpx;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12), transparent 66%);
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.24);
  border-radius: 999rpx;
  color: #ffe0a0;
  font-size: 18rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.hero-title-en {
  margin: 22rpx 0 8rpx;
  width: 560rpx;
  font-family: 'Times New Roman', serif;
  font-size: 68rpx;
  line-height: 1.04;
  font-style: italic;
  font-weight: 700;
  white-space: pre-line;
}

.hero-title-zh {
  color: #edf7ff;
  font-size: 28rpx;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
}

.hero-copy {
  width: 470rpx;
  color: rgba(255, 255, 255, 0.95);
  font-size: 28rpx;
  line-height: 1.55;
}

.hero-copy-en {
  width: 470rpx;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-family: 'Times New Roman', serif;
  font-style: italic;
  font-size: 26rpx;
  line-height: 1.45;
}

.hero-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.primary-btn,
.secondary-btn,
.outline-btn {
  min-width: 164rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin: 0;
}

.primary-btn {
  color: #4f3c17;
  background: #efbc52;
}

.secondary-btn {
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.24);
  background: rgba(255, 255, 255, 0.10);
}

.outline-btn {
  color: #145ea8;
  border: 2rpx solid #dce9f6;
  background: #ffffff;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin: 16rpx 0 14rpx;
}

.section-head-title {
  color: #145ea8;
  font-size: 30rpx;
  font-weight: 700;
}

.section-head-subtitle {
  color: #70849a;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.quick-card,
.glass-card,
.list-card,
.soft-card,
.menu-card,
.timeline-card,
.empty-card,
.advisor-card,
.stats-card,
.note-card {
  border-radius: 20rpx;
  border: 2rpx solid rgba(75, 120, 170, 0.12);
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 24rpx rgba(56, 96, 140, 0.05);
}

.quick-card {
  padding: 18rpx 10rpx 16rpx;
  text-align: center;
}

.quick-icon {
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto 10rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #145ea8;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #eef6fd, #fff5de);
}

.quick-label {
  color: #687a8c;
  font-size: 26rpx;
  line-height: 1.35;
}

.quick-meta {
  color: #90a0b2;
  font-size: 18rpx;
  margin-top: 6rpx;
}

.visual-swiper {
  height: 292rpx;
  margin: 20rpx 0 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 32rpx rgba(31, 98, 167, 0.12);
}

.visual-hero-shell {
  position: relative;
  height: 780rpx;
  margin-top: 6rpx;
  border-radius: 0;
  overflow: hidden;
  box-shadow: 0 18rpx 40rpx rgba(12, 74, 135, 0.16);
}

.visual-swiper-hero {
  height: 780rpx;
  margin: 0;
  border-radius: 0;
  box-shadow: none;
}

.visual-swiper-hero .visual-slide {
  height: 780rpx;
  border-radius: 0;
}

.visual-slide {
  position: relative;
  width: 100%;
  height: 292rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #145ea8;
}

.visual-image {
  width: 100%;
  height: 100%;
  display: block;
}

.visual-mask {
  position: absolute;
  inset: 0;
  z-index: 2;
  background:
    linear-gradient(180deg, rgba(2, 83, 151, 0.94), rgba(2, 83, 151, 0.82)),
    linear-gradient(90deg, rgba(4, 60, 115, 0.88), rgba(18, 103, 176, 0.56) 64%, rgba(4, 60, 115, 0.40));
  pointer-events: none;
}

.visual-copy {
  position: absolute;
  z-index: 3;
  left: 48rpx;
  right: 48rpx;
  top: 64rpx;
  bottom: 46rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  pointer-events: none;
}

.visual-badge {
  align-self: flex-start;
  width: 100%;
  padding: 16rpx 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.30);
  color: #f5d98a;
  font-size: 20rpx;
  letter-spacing: 7rpx;
  text-transform: uppercase;
}

.visual-title-en {
  color: #ffffff;
  width: 590rpx;
  margin-top: 72rpx;
  font-family: 'Times New Roman', serif;
  font-size: 68rpx;
  line-height: 1.04;
  font-style: italic;
  font-weight: 700;
  white-space: pre-line;
  text-shadow: 0 4rpx 12rpx rgba(0, 32, 70, 0.28);
}

.visual-title-zh {
  margin-top: 38rpx;
  color: rgba(237, 247, 255, 0.74);
  font-size: 30rpx;
  letter-spacing: 5rpx;
  line-height: 1.55;
  text-shadow: 0 4rpx 12rpx rgba(0, 32, 70, 0.24);
}

.visual-desc {
  width: 580rpx;
  margin-top: auto;
  color: rgba(255, 255, 255, 0.82);
  font-size: 30rpx;
  letter-spacing: 3rpx;
  line-height: 1.45;
}

.visual-desc-en {
  width: 560rpx;
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.72);
  font-family: 'Times New Roman', serif;
  font-size: 28rpx;
  font-style: italic;
  line-height: 1.45;
}

.visual-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28rpx;
  width: 100%;
  margin-top: 30rpx;
}

.visual-primary,
.visual-secondary {
  min-height: 94rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.visual-primary {
  color: #263216;
  background: #d6a92a;
}

.visual-secondary {
  color: #ffffff;
  border: 2rpx solid rgba(255, 255, 255, 0.32);
  background: rgba(255, 255, 255, 0.04);
  text-transform: uppercase;
}

.search-entry {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: 72rpx 1fr 128rpx;
  align-items: center;
  gap: 12rpx;
  min-height: 112rpx;
  margin: 22rpx 0 24rpx;
  padding: 16rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 16rpx 34rpx rgba(31, 98, 167, 0.16);
}

.search-symbol {
  position: relative;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid #d8e4f0;
}

.search-symbol::after {
  content: '';
  position: absolute;
  right: -8rpx;
  bottom: 2rpx;
  width: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #d8e4f0;
  transform: rotate(45deg);
}

.search-copy {
  display: flex;
  flex-direction: column;
  line-height: 1.25;
}

.search-title {
  color: #13263f;
  font-size: 32rpx;
  font-weight: 700;
}

.search-subtitle {
  margin-top: 6rpx;
  color: #9aa9b8;
  font-size: 24rpx;
}

.search-btn {
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #efbc52, #d69b28);
}

.quick-grid-illustrated {
  grid-template-columns: repeat(4, 1fr);
  margin-bottom: 20rpx;
}

.quick-grid-illustrated .quick-card {
  min-height: 178rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
}

.quick-visual {
  position: relative;
  width: 92rpx;
  height: 78rpx;
  margin: 0 auto 12rpx;
}

.quick-shape {
  position: absolute;
  box-sizing: border-box;
}

.quick-visual-training .quick-shape-a {
  left: 18rpx;
  bottom: 8rpx;
  width: 52rpx;
  height: 42rpx;
  border-radius: 10rpx 10rpx 4rpx 4rpx;
  border: 5rpx solid #efbc52;
  border-top: 0;
}

.quick-visual-training .quick-shape-b {
  left: 26rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-left: 5rpx solid #145ea8;
  border-top: 5rpx solid #145ea8;
  transform: rotate(45deg);
}

.quick-visual-training .quick-shape-c {
  right: 12rpx;
  top: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #efbc52;
}

.quick-visual-renewal .quick-shape-a,
.quick-visual-renewal .quick-shape-b {
  bottom: 10rpx;
  width: 34rpx;
  height: 48rpx;
  border-radius: 999rpx 999rpx 12rpx 12rpx;
  background: #efbc52;
}

.quick-visual-renewal .quick-shape-a {
  left: 18rpx;
  transform: rotate(-18deg);
}

.quick-visual-renewal .quick-shape-b {
  right: 18rpx;
  background: #4ea4f5;
  transform: rotate(18deg);
}

.quick-visual-renewal .quick-shape-c {
  left: 38rpx;
  top: 10rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #145ea8;
}

.quick-visual-healing .quick-shape-a {
  left: 20rpx;
  top: 12rpx;
  width: 52rpx;
  height: 52rpx;
  border: 7rpx solid #efbc52;
  border-radius: 50%;
}

.quick-visual-healing .quick-shape-b {
  left: 42rpx;
  top: 4rpx;
  width: 8rpx;
  height: 68rpx;
  border-radius: 999rpx;
  background: #4ea4f5;
}

.quick-visual-healing .quick-shape-c {
  left: 12rpx;
  top: 34rpx;
  width: 68rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #4ea4f5;
}

.quick-visual-travel .quick-shape-a {
  left: 18rpx;
  bottom: 10rpx;
  width: 56rpx;
  height: 36rpx;
  border-radius: 6rpx;
  border: 5rpx solid #efbc52;
}

.quick-visual-travel .quick-shape-b {
  left: 30rpx;
  top: 8rpx;
  width: 34rpx;
  height: 42rpx;
  border-radius: 20rpx 20rpx 4rpx 4rpx;
  background: #145ea8;
}

.quick-visual-travel .quick-shape-c {
  right: 8rpx;
  bottom: 16rpx;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #4ea4f5;
}

.featured-route {
  position: relative;
  overflow: hidden;
  margin: 28rpx 0 24rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 2rpx solid rgba(75, 120, 170, 0.12);
  box-shadow: 0 18rpx 38rpx rgba(31, 98, 167, 0.10);
}

.featured-route-editorial {
  display: grid;
  grid-template-columns: 1fr 250rpx;
  gap: 22rpx;
  min-height: 310rpx;
  padding: 24rpx;
}

.featured-route-image {
  width: 100%;
  height: 100%;
  display: block;
}

.featured-route-mask {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(9, 50, 91, 0.76), rgba(9, 50, 91, 0.18) 68%),
    linear-gradient(180deg, transparent 36%, rgba(9, 50, 91, 0.40));
}

.featured-route-content {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 26rpx;
  color: #ffffff;
}

.featured-route-copy {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.featured-route-tag {
  display: inline-flex;
  align-self: flex-start;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #4f3c17;
  background: #efbc52;
  font-size: 22rpx;
  font-weight: 800;
}

.featured-route-title {
  margin-top: 16rpx;
  color: #13263f;
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.featured-route-desc {
  margin-top: 8rpx;
  color: #145ea8;
  font-size: 25rpx;
  font-weight: 700;
}

.featured-route-text {
  margin-top: 16rpx;
  color: #70849a;
  font-size: 24rpx;
  line-height: 1.55;
}

.featured-route-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 18rpx;
  color: #70849a;
  font-size: 20rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.featured-route-square {
  width: 250rpx;
  height: 250rpx;
  display: block;
  border-radius: 18rpx;
  background: #eef6fd;
}

.brand-manifesto {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-left: 6rpx solid #d6a92a;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(239, 246, 254, 0.90));
}

.manifesto-kicker {
  color: #145ea8;
  font-size: 18rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.manifesto-copy {
  margin-top: 16rpx;
  color: #13263f;
  font-size: 27rpx;
  line-height: 1.65;
}

.manifesto-copy-en {
  margin-top: 14rpx;
  color: #70849a;
  font-family: 'Times New Roman', serif;
  font-size: 24rpx;
  font-style: italic;
  line-height: 1.55;
}

.chip-row {
  display: flex;
  gap: 12rpx;
  overflow: hidden;
  margin-bottom: 14rpx;
}

.chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #145ea8;
  font-size: 24rpx;
  background: #eff6fe;
}

.chip-active {
  color: #ffffff;
  background: linear-gradient(135deg, #4ca5f6, #1972c8);
}

.two-col-grid,
.stats-grid,
.contact-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.route-square-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.route-square-card {
  overflow: hidden;
  border-radius: 24rpx;
  border: 2rpx solid rgba(75, 120, 170, 0.12);
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 24rpx rgba(56, 96, 140, 0.06);
}

.glass-card,
.form-card,
.stats-card,
.note-card {
  min-height: 154rpx;
  padding: 18rpx;
}

.route-thumb-image {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #eef6fd;
}

.route-square-body {
  min-height: 180rpx;
  padding: 18rpx;
}

.card-title {
  color: #13263f;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.card-subtitle {
  color: #efbc52;
  font-size: 18rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  margin-bottom: 8rpx;
}

.card-copy,
.info-value {
  color: #70849a;
  font-size: 26rpx;
  line-height: 1.5;
}

.field-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.field,
.textarea {
  width: 100%;
  min-height: 70rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  border: 2rpx solid #edf2f8;
  background: #fbfdff;
  color: #425b76;
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.textarea {
  min-height: 110rpx;
  padding: 18rpx;
  line-height: 1.5;
}

.list-card,
.timeline-card {
  margin-bottom: 12rpx;
  padding: 16rpx;
}

.list-card {
  display: grid;
  grid-template-columns: 84rpx 1fr;
  gap: 12rpx;
}

.thumb {
  position: relative;
  overflow: hidden;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #4f96df, #144f8d 62%, #f2ca7d 100%);
}

.thumb::before {
  content: '';
  position: absolute;
  width: 42rpx;
  height: 42rpx;
  left: 21rpx;
  top: 18rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 50%;
  box-shadow: 0 0 0 12rpx rgba(255, 255, 255, 0.05);
}

.thumb::after {
  content: '✦';
  position: absolute;
  left: 34rpx;
  top: 28rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 24rpx;
  font-weight: 700;
}

.soft-card {
  margin-top: 12rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #f6faff;
  border-left: 4rpx solid #efbc52;
}

.soft-title,
.info-label {
  color: #13263f;
  font-size: 24rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.soft-copy {
  color: #70849a;
  font-size: 24rpx;
  line-height: 1.46;
}

.profile-card,
.advisor-card {
  padding: 18rpx;
  border-radius: 24rpx;
  color: #ffffff;
  background: linear-gradient(135deg, rgba(25, 114, 200, 0.94), rgba(87, 164, 240, 0.76));
  box-shadow: 0 18rpx 36rpx rgba(31, 98, 167, 0.16);
}

.profile-row,
.advisor-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 14rpx;
}

.avatar,
.advisor-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.92);
  color: #145ea8;
  font-size: 24rpx;
  font-weight: 900;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.metric {
  padding: 10rpx 6rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.18);
  text-align: center;
}

.metric-num,
.stats-value {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
}

.metric-label,
.stats-label,
.timeline-meta,
.status-pill {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.menu-card {
  margin-top: 12rpx;
  overflow: hidden;
}

.menu-row,
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1px solid #eef3f8;
  font-size: 28rpx;
}

.menu-row:last-child,
.info-row:last-child {
  border-bottom: 0;
}

.menu-meta,
.info-meta {
  color: #7c8ea2;
  font-size: 22rpx;
  letter-spacing: 2rpx;
}

.page-overview {
  margin-bottom: 12rpx;
  padding: 20rpx;
}

.overview-kicker {
  color: #6f8398;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

.overview-title {
  margin-top: 10rpx;
  color: #13263f;
  font-size: 36rpx;
  font-weight: 700;
}

.overview-copy {
  margin-top: 10rpx;
  color: #70849a;
  font-size: 24rpx;
  line-height: 1.6;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #145ea8;
  background: #eef6ff;
}

.timeline-card {
  position: relative;
  padding-left: 24rpx;
}

.timeline-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #4ca5f6, #efbc52);
}

.timeline-title {
  color: #13263f;
  font-size: 28rpx;
  font-weight: 700;
}

.timeline-copy {
  margin-top: 8rpx;
  color: #70849a;
  font-size: 24rpx;
  line-height: 1.55;
}

.timeline-foot {
  margin-top: 14rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.timeline-meta {
  color: #90a0b2;
}

.empty-card {
  padding: 22rpx 20rpx;
  text-align: center;
}

.empty-title {
  color: #13263f;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-copy {
  margin-top: 8rpx;
  color: #70849a;
  font-size: 24rpx;
  line-height: 1.55;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.info-item {
  padding: 16rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 2rpx solid #edf2f8;
}

.note-card {
  margin-top: 12rpx;
}

.contact-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}
