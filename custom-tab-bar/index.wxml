<view class="tabbar-shell">
  <view wx:for="{{list}}" wx:key="pagePath" class="tab-item {{selected === index ? 'active' : ''}}" data-path="{{item.pagePath}}" data-index="{{index}}" bindtap="switchTab">
    <view class="tab-icon {{item.iconClass}}"></view>
    <text>{{item.text}}</text>
  </view>
</view>
